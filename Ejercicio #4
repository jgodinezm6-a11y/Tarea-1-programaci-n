#include <iostream>
#include <cstring>
using namespace std;
void invertirSegmento(char cadena[], int a, int b) {
    int n = strlen(cadena);
    if (b >= n) {
        b = n - 1;
    }
    if (a < 0 || a >= n || b < 0 || a > b) {
        cout << "Índices inválidos." << endl;
        return;
    }while (a < b) {
        char temp = cadena[a];
        cadena[a] = cadena[b];
        cadena[b] = temp;
        a++;
        b--;
    }
}
int main() {
    char texto[100];
    int a, b;
    cout << "Ingrese una cadena: ";
    cin.getline(texto, 100);
    cout << "Ingrese índice inicial (a): ";
    cin >> a;
    cout << "Ingrese índice final (b): ";
    cin >> b;
    invertirSegmento(texto, a, b);
    cout << "Resultado: " << texto << endl;

    return 0;
}
